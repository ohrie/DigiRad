  <widget class="QWizardPage" name="routingPage">
   <property name="title">
    <string>Umlegung auf Verkehrsnetz</string>
   </property>
   <property name="subTitle">
    <string>Legen Sie das Luftliniennetz auf ein bestehendes Verkehrsnetz um</string>
   </property>
   <layout class="QVBoxLayout" name="verticalLayout_14">
    <item>
     <widget class="QGroupBox" name="networkGroupBox">
      <property name="title">
       <string>Verkehrsnetz</string>
      </property>
      <layout class="QVBoxLayout" name="verticalLayout_15">
       <item>
        <widget class="QLabel" name="networkLabel">
         <property name="text">
          <string>Wählen Sie einen bestehenden Linienlayer als Verkehrsnetz:</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QComboBox" name="networkLayerComboBox"/>
       </item>
       <item>
        <layout class="QHBoxLayout" name="networkButtonsLayout">
         <item>
          <widget class="QPushButton" name="refreshNetworkLayersButton">
           <property name="text">
            <string>Layer aktualisieren</string>
           </property>
           <property name="icon">
            <iconset>
             <normaloff>:/plugins/verkehrsnetz_generator/icons/refresh.png</normaloff>:/plugins/verkehrsnetz_generator/icons/refresh.png</iconset>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="importNetworkLayerButton">
           <property name="text">
            <string>Neuen Layer laden</string>
           </property>
           <property name="icon">
            <iconset>
             <normaloff>:/plugins/verkehrsnetz_generator/icons/add_layer.png</normaloff>:/plugins/verkehrsnetz_generator/icons/add_layer.png</iconset>
           </property>
          </widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="routingOptionsGroupBox">
      <property name="title">
       <string>Routingoptionen</string>
      </property>
      <layout class="QVBoxLayout" name="verticalLayout_16">
       <item>
        <layout class="QFormLayout" name="formLayout_4">
         <item row="0" column="0">
          <widget class="QLabel" name="costFieldLabel">
           <property name="text">
            <string>Attribut für Kosten:</string>
           </property>
          </widget>
         </item>
