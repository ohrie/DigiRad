<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>VerkehrsnetzWizard</class>
 <widget class="QWizard" name="VerkehrsnetzWizard">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>700</width>
    <height>500</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Verkehrsnetz Erstellung</string>
  </property>
  <property name="wizardStyle">
   <enum>QWizard::ModernStyle</enum>
  </property>
  <property name="options">
   <set>QWizard::HaveHelpButton|QWizard::HelpButtonOnRight</set>
  </property>
  <widget class="QWizardPage" name="welcomePage">
   <property name="title">
    <string>Willkommen zum Verkehrsnetz-Generator</string>
   </property>
   <property name="subTitle">
    <string>Dieses Tool hilft Ihnen bei der Erstellung eines Verkehrsnetzes in mehreren Schritten</string>
   </property>
   <layout class="QVBoxLayout" name="verticalLayout">
    <item>
     <widget class="QLabel" name="welcomeLabel">
      <property name="text">
       <string>Mit diesem Assistenten können Sie ein Verkehrsnetz erstellen und bearbeiten. Der Prozess umfasst folgende Schritte:

1. Auswahl des Gebiets/Ortes
2. Festlegung zentraler Punkte/Orte
3. Erstellung eines Luftliniennetzes
4. Umlegung auf ein bestehendes Verkehrsnetz

Zu Beginn können Sie ein bestehendes Projekt laden oder ein neues erstellen.

Klicken Sie auf &quot;Weiter&quot;, um zu beginnen.</string>
      </property>
      <property name="alignment">
       <set>Qt::AlignLeading|Qt::AlignLeft|Qt::AlignTop</set>
      </property>
      <property name="wordWrap">
       <bool>true</bool>
      </property>
     </widget>
    </item>
    <item>
     <widget class="QLabel" name="imageLabel">
      <property name="minimumSize">
       <size>
        <width>0</width>
        <height>200</height>
       </size>
      </property>
      <property name="text">
       <string/>
      </property>
      <property name="pixmap">
       <pixmap>verkehrsnetz_beispiel.png</pixmap>
      </property>
      <property name="scaledContents">
       <bool>false</bool>
      </property>
      <property name="alignment">
       <set>Qt::AlignCenter</set>
      </property>
     </widget>
    </item>
    <item>
     <layout class="QHBoxLayout" name="projectButtonsLayout">
      <item>
       <widget class="QPushButton" name="loadProjectButton">
        <property name="text">
         <string>Projekt laden</string>
        </property>
        <property name="icon">
         <iconset>
          <normaloff>:/plugins/verkehrsnetz_generator/icons/open.png</normaloff>:/plugins/verkehrsnetz_generator/icons/open.png</iconset>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="newProjectButton">
        <property name="text">
         <string>Neues Projekt</string>
        </property>
        <property name="icon">
         <iconset>
          <normaloff>:/plugins/verkehrsnetz_generator/icons/new.png</normaloff>:/plugins/verkehrsnetz_generator/icons/new.png</iconset>
        </property>
       </widget>
      </item>
     </layout>
    </item>
   </layout>
  </widget>
  <widget class="QWizardPage" name="locationPage">
   <property name="title">
    <string>Ortsauswahl</string>
   </property>
   <property name="subTitle">
    <string>Wählen Sie den Ort/die Region, für den/die Sie das Verkehrsnetz erstellen möchten</string>
   </property>
   <layout class="QVBoxLayout" name="verticalLayout_2">
    <item>
     <widget class="QLabel" name="locationLabel">
      <property name="text">
       <string>Geben Sie den Namen des Ortes oder der Region ein:</string>
      </property>
     </widget>
    </item>
    <item>
     <layout class="QHBoxLayout" name="searchLayout">
      <item>
       <widget class="QLineEdit" name="locationLineEdit">
        <property name="placeholderText">
         <string>z.B. Berlin, Brandenburg, etc.</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="searchButton">
        <property name="text">
         <string>Suchen</string>
        </property>
        <property name="icon">
         <iconset>
          <normaloff>:/plugins/verkehrsnetz_generator/icons/search.png</normaloff>:/plugins/verkehrsnetz_generator/icons/search.png</iconset>
        </property>
       </widget>
      </item>
     </layout>
    </item>
    <item>
     <widget class="QLabel" name="resultsLabel">
      <property name="text">
       <string>Suchergebnisse:</string>
      </property>
     </widget>
    </item>
    <item>
     <widget class="QListWidget" name="resultsListWidget">
      <property name="selectionMode">
       <enum>QAbstractItemView::SingleSelection</enum>
      </property>
     </widget>
    </item>
    <item>
     <widget class="QGroupBox" name="extentGroupBox">
      <property name="title">
       <string>Ausdehnung</string>
      </property>
      <layout class="QGridLayout" name="gridLayout">
       <item row="0" column="0">
        <widget class="QLabel" name="bufferLabel">
         <property name="text">
          <string>Puffer um ausgewählten Ort (km):</string>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QDoubleSpinBox" name="bufferSpinBox">
         <property name="decimals">
          <number>1</number>
         </property>
         <property name="minimum">
          <double>0.500000000000000</double>
         </property>
         <property name="maximum">
          <double>100.000000000000000</double>
         </property>
         <property name="singleStep">
          <double>0.500000000000000</double>
         </property>
         <property name="value">
          <double>5.000000000000000</double>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>
   </layout>
  </widget>
