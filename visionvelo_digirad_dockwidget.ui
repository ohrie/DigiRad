         <widget class="QLabel" name="welcomeInfoLabel">
          <property name="text">
           <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p align=&quot;justify&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Willkommen zum Verkehrsnetz-Generator&lt;/span&gt;&lt;/p&gt;&lt;p align=&quot;justify&quot;&gt;Dieses Tool hilft Ihnen bei der Erstellung eines Radverkehrsnetzes in mehreren Schritten.&lt;/p&gt;&lt;p align=&quot;justify&quot;&gt;Mit diesem Assistenten können Sie ein Verkehrsnetz erstellen und bearbeiten.&lt;/p&gt;&lt;p align=&quot;justify&quot;&gt;Der Prozess umfasst folgende Schritte:&lt;/p&gt;&lt;ol style=&quot;margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;&quot;&gt;&lt;li align=&quot;justify&quot; style=&quot; margin-top:12px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Auswahl des Gebiets/Ortes&lt;/li&gt;&lt;li align=&quot;justify&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Festlegung zentraler Punkte/Orte&lt;/li&gt;&lt;li align=&quot;justify&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Erstellung eines Luftliniennetzes&lt;/li&gt;&lt;li align=&quot;justify&quot; style=&quot; margin-top:0px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Umlegung auf ein bestehendes Verkehrsnetz&lt;/li&gt;&lt;/ol&gt;&lt;p align=&quot;justify&quot;&gt;Klicken Sie auf &lt;span style=&quot; font-weight:600;&quot;&gt;Weiter&lt;/span&gt;, um zu beginnen oder auf &lt;span style=&quot; font-weight:600;&quot;&gt;Projekt laden&lt;/span&gt; um ein bestehendes Projekt zu laden.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
          </property>
