           <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Netzumlegung&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Basierend auf dem Luftliniennetz wird nun eine Umlegung auf ein vorhandenes Routennetz vorgenommen.&lt;/p&gt;&lt;p&gt;Dafür muss ein digitales Verkehrsnetz für die ausgewählte Region mit den folgenden Eigenschaften geladen werden:&lt;/p&gt;&lt;ul style=&quot;margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;&quot;&gt;&lt;li style=&quot; margin-top:0px; margin-bottom:0px; margin-left:-10px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;vollständige Abdeckung des Luftliniennetzes&lt;/li&gt;&lt;li style=&quot; margin-top:0px; margin-bottom:0px; margin-left:-10px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Routenfähigkeit ohne topologische Inseln&lt;/li&gt;&lt;li style=&quot; margin-top:0px; margin-bottom:5px; margin-left:-10px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Koordinatenreferenzsystem in EPSG 25832&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;br/&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
